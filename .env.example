# 你**不需要**手动编辑这个文件。双击 console.bat，在「配置」页填表就行。
# 想手工改也可以：复制成 .env，填下面的值。
# .env 里有密钥和你的 QQ 号，已经在 .gitignore 里，永远不要提交它。
#
# 手把手部署步骤见 README.md。

# ============================================================
# NoneBot2 核心配置（一般不用改）
# ============================================================
# 只监听本机，**别改**。这个端口上除了 NapCat 的反向连接，还有一个内部接口
# （/api/internal/resend），桌面控制台靠它让 bot 补发消息。绑到 0.0.0.0 等于把
# 「让你的 bot 往群里发消息」这个能力交给整个局域网。
HOST=127.0.0.1
PORT=8081
COMMAND_START=["/"]
LOG_LEVEL=INFO

# ============================================================
# 必填：监听哪里、推送到哪里、谁是管理员
# ============================================================
# 要监听的羊毛群号（逗号分隔）。bot 必须已经在这些群里。
WOOL_GROUP_IDS=

# 推送到哪些群（逗号分隔）。这也是 /w 命令唯一生效的群——
# 在别的群里发 /w 命令，bot 会装作没看见。
FORWARD_GROUP_IDS=

# 管理员 QQ 号（逗号分隔）。管理命令（/w pause、/w list all 等）只在私聊生效。
# ADMIN_ID（单数）和 ADMIN_IDS（复数）都认，填任意一个即可。
ADMIN_IDS=

# ============================================================
# NapCat（只有桌面控制台读这两个，bot 不需要）
# ============================================================
# NapCat 的安装目录——就是含 NapCatWinBootMain.exe 的那个文件夹。
# 留空 = 控制台自动找（先看正在跑的 NapCat 进程，再扫常见位置）。
# 填了之后，控制台就能替你无窗口地启停 NapCat、自动配好反向 WS，
# 你再也不用开它的黑框，也不用进 WebUI 手点。
NAPCAT_DIR=

# 机器人的 QQ 号（一个纯数字）。控制台用它免扫码快速登录——
# 这个号必须先在 NapCat 里扫码登录过一次。留空就每次都要扫码。
# ⚠ 填机器人小号，不是你自己的号。它会被自动化操作，有封号风险。
NAPCAT_QQ=

# ============================================================
# AI 质量把关（支持多种模型）
# ============================================================
# 用来判断「这是一个具体商品的优惠，还是签到打卡拉人头的活动帖」。
# 它不判断价格划不划算——那由你自己设的金额门槛决定。
# 不填也能跑：AI 环节一律放行，只剩正则过滤，噪音会多一些。
#
# 底层只用 OpenAI 兼容的 /chat/completions 协议，所以 DeepSeek / Kimi / 智谱 GLM /
# 通义千问 Qwen / OpenAI 等任何兼容服务都能用——控制台「配置」页有服务商下拉，
# 选一下就会自动填好下面的地址和模型，一般不用手动改这个文件。
#
# API Key（键名沿用 DEEPSEEK_API_KEY，但对任何服务商都是填这一个）
DEEPSEEK_API_KEY=

# 接口地址。留空 = DeepSeek。其它示例：
#   Kimi     https://api.moonshot.cn/v1
#   智谱 GLM  https://open.bigmodel.cn/api/paas/v4
#   通义千问  https://dashscope.aliyuncs.com/compatible-mode/v1
#   OpenAI   https://api.openai.com/v1
AI_BASE_URL=

# 模型名。留空 = deepseek-chat。换成 moonshot-v1-8k / glm-4-flash / qwen-turbo /
# gpt-4o-mini 等，要和上面的接口地址对应。
AI_MODEL=

# ============================================================
# 微博监控（可选，不填就只监听 QQ 群）
# ============================================================
# 博主 UID（数字，逗号分隔）。打开博主主页 https://weibo.com/u/1234567890 → 后面那串就是。
WEIBO_UIDS=

# 检查间隔（秒），默认 5 分钟。别低于 60 秒，容易被风控。
WEIBO_CHECK_INTERVAL=300

# 微博登录 Cookie。强烈建议填：不填也能跑，但匿名请求大概率被限流返回空数据。
# 在控制台「配置」页点「扫码登录」自动获取。Cookie 会过期，失效时 bot 会私信管理员提醒。
WEIBO_COOKIE=

# 连续失败多少次才告警一次（默认 5 次，配合 300 秒间隔 ≈ 25 分钟）
WEIBO_FAIL_ALERT_THRESHOLD=5

# ============================================================
# 其它
# ============================================================
# 跨源去重窗口（秒）：同一条羊毛在这个时间内不会被重复推送。默认 30 分钟。
DEDUP_SECONDS=1800
